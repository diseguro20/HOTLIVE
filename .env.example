# Front-end endpoint used by the coin store.
# In development this is served by vite.config.js.
VITE_PAYMENT_API_BASE=/api/payments

# Supabase project settings (Project Settings > API).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Auth/profile API used when the browser does not receive a Supabase public key.
VITE_PLATFORM_API_BASE=/api/platform

# Server-only Supabase credentials. Never prefix the service key with VITE_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Leave true only while testing without Vizzion Pay credentials.
VIZZION_PAY_MOCK=true

# Official API base, routes and credentials generated in Integrations > API.
VIZZION_PAY_API_BASE=https://app.vizzionpay.com.br/api/v1
VIZZION_PAY_CREATE_PAYMENT_PATH=/gateway/pix/receive
VIZZION_PAY_STATUS_PATH=/gateway/transactions?id=:id
VIZZION_PAY_PUBLIC_KEY=
VIZZION_PAY_SECRET_KEY=

# Public endpoint used by Vizzion Pay payment webhooks.
# Example: https://api.seudominio.com/api/payments/webhooks/vizzion
VIZZION_PAY_WEBHOOK_URL=

# Token generated when the internal checkout webhook is created in Vizzion Pay.
VIZZION_PAY_WEBHOOK_TOKEN=

# Hosted credit-card checkout and offer code for each coin package.
VIZZION_PAY_CARD_CHECKOUT_COINS_120=
VIZZION_PAY_CARD_OFFER_COINS_120=
VIZZION_PAY_CARD_CHECKOUT_COINS_240=
VIZZION_PAY_CARD_OFFER_COINS_240=
VIZZION_PAY_CARD_CHECKOUT_COINS_600=
VIZZION_PAY_CARD_OFFER_COINS_600=
VIZZION_PAY_CARD_CHECKOUT_COINS_1200=
VIZZION_PAY_CARD_OFFER_COINS_1200=
VIZZION_PAY_CARD_CHECKOUT_COINS_2400=
VIZZION_PAY_CARD_OFFER_COINS_2400=
VIZZION_PAY_CARD_CHECKOUT_COINS_3600=
VIZZION_PAY_CARD_OFFER_COINS_3600=
VIZZION_PAY_CARD_CHECKOUT_COINS_6000=
VIZZION_PAY_CARD_OFFER_COINS_6000=
VIZZION_PAY_CARD_CHECKOUT_COINS_13200=
VIZZION_PAY_CARD_OFFER_COINS_13200=
VIZZION_PAY_CARD_CHECKOUT_COINS_27600=
VIZZION_PAY_CARD_OFFER_COINS_27600=
ADMIN_EMAILS=admin@example.com
